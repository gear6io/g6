# web/ frontend configuration. Copy to `.env` and adjust. Vite only exposes vars
# prefixed VITE_ to client code.

# Backend WebSocket origin. HTTP calls derive from this (ws:// -> http://). Defaults
# to the backend's own default when unset. The Nostr-shaped repo/invite features
# also read this, though they have no backend counterpart yet.
VITE_RELAY_URL=ws://localhost:3000

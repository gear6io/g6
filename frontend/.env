# Route the frontend at the gear6 backend (HTTP + /rtm ws) instead of the
# removed nostr/Tauri command backend. Without this, invokeTauri calls the
# real (unregistered) Tauri commands and apply_workspace fails with
# "Command apply_workspace not found". Must be set for every launch path
# (vite dev, pnpm build, tauri beforeDevCommand), so it lives here not in
# a single command.
VITE_GEAR6=1

# gear6 backend configuration. Copy to `.env` and adjust. All values shown are the
# built-in defaults, so an empty `.env` behaves identically to none.

# SQLite connection string (rwc = read/write/create).
DATABASE_URL=sqlite://gear6.db?mode=rwc

# HTTP listen port.
PORT=3000

# Absolute URLs the backend hands out to clients.
GEAR6_PUBLIC_URL=http://localhost:3000/
GEAR6_WS_URL=ws://localhost:3000

# Single allowed CORS origin. Default matches web/'s Vite dev server.
GEAR6_CORS_ORIGIN=http://localhost:5173

# Workspace/team display name.
GEAR6_TEAM_NAME=gear6

# LOCAL DEV ONLY. When truthy, a request with no Authorization header is resolved as
# a fixed `dev` user instead of rejected — lets web/ (which has no login UI) connect
# with zero credentials. Leave unset in any real deployment.
GEAR6_DISABLE_AUTH=true
